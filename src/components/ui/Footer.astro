---
import { guides } from '../../data/guides';
---

<footer class="border-t border-warm-200 py-8">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <nav aria-label="Guides" class="flex flex-wrap gap-x-6 gap-y-2 mb-6 pb-6 border-b border-warm-200 text-sm text-warm-600">
      {
        guides.map((g) => (
          <a href={g.href} class="hover:text-warm-900 transition-colors">{g.label}</a>
        ))
      }
    </nav>

    <div class="flex flex-col sm:flex-row justify-between items-center gap-4 text-sm text-warm-600">
      <span>
        Made by <a
          href="https://github.com/kauredo"
          target="_blank"
          rel="noopener noreferrer"
          class="text-warm-700 hover:text-primary-600 transition-colors"
        >kauredo</a>
      </span>

      <div class="flex items-center gap-6">
        <a
          href="https://basketballstatsapp.com?utm_source=basketballvideoanalyzer&utm_medium=website&utm_campaign=cross-link"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-warm-900 transition-colors"
        >
          Basketball Stats App
        </a>
        <a
          href="https://github.com/kauredo/basketball-video-analyzer"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-warm-900 transition-colors"
        >
          GitHub
        </a>
        <a
          href="https://github.com/kauredo/basketball-video-analyzer/issues"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-warm-900 transition-colors"
        >
          Issues
        </a>
        <a
          href="https://github.com/kauredo/basketball-video-analyzer/releases"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:text-warm-900 transition-colors"
        >
          Releases
        </a>
        <a
          href="mailto:contact@basketballvideoanalyzer.com"
          class="hover:text-warm-900 transition-colors"
        >
          Contact
        </a>
      </div>
    </div>
  </div>
</footer>
